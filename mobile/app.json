{
  "expo": {
    "name": "Vault Wallet",
    "slug": "vault-wallet",
    "version": "0.1.0",
    "scheme": "vaultwallet",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0E",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vaultwallet.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock your wallet with Face ID."
      }
    },
    "android": {
      "package": "app.vaultwallet.mobile",
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.USE_BIOMETRIC"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-local-authentication",
        { "faceIDPermission": "Unlock your wallet with Face ID." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
